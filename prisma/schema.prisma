generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  age              Int?
  biologicalSex    String?
  weeklyMileage    String?
  experienceLevel  String?
  onboardingDone   Boolean @default(false)
  sport            String? @default("track")

  currentWakeTime  String?
  currentBedTime   String?
  restedFeeling    String?

  notifPhase1      Boolean @default(true)
  notifPhase2      Boolean @default(true)
  notifPhase3      Boolean @default(true)
  notifPhase4      Boolean @default(true)

  stravaAccessToken   String?
  stravaRefreshToken  String?
  stravaTokenExpiry   DateTime?
  stravaAthleteId     String?
  stravaConnected     Boolean   @default(false)
  userMaxHR           Int?
  userThresholdHR     Int?

  workouts         Workout[]
  meets            Meet[]
  sessions         Session[]
  stravaActivities StravaActivity[]
}

model StravaActivity {
  id              String   @id @default(cuid())
  stravaId        String   @unique
  userId          String
  name            String
  startDate       DateTime
  distance        Float
  movingTime      Int
  elapsedTime     Int
  totalElevGain   Float
  averageSpeed    Float
  maxSpeed        Float
  averageHeartrate Float?
  maxHeartrate    Float?
  sufferScore     Int?
  workoutType     Int?
  averageCadence  Float?
  externalId      String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  type        String
  distance    Float?
  duration    Int?
  effort      Int?
  isTemplate  Boolean  @default(false)
  dayOfWeek   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Meet {
  id        String   @id @default(cuid())
  userId    String
  name      String
  date      DateTime
  distances String
  priority  String
  raceTime  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
